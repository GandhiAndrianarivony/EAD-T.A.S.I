	url = {https://ieeexplore.ieee.org/document/9074261/},
	doi = {10.1109/ICACCS48705.2020.9074261},
	abstract = {Ecological checking, earth-assets mappings, and military frameworks require expansive territory imaging to achieve perfection. Frequently, these pictures must be obtained during the night or during the severe climate. Synthetic-aperture radars ({SAR}) give such a capacity. Engineered aperture radar frameworks will exploit the long-run spread attributes of a radar signal and the preparation of the intricate data abilities of present-day computerized electronic gadgets to give a high-goals picture. {SAR} is an emerging technology that has been widely used for more than 20 years in remote sensing areas. It is quite complicate to take an image in remote sensing areas without the use of {SARs}. This paper provides an overall view of a {SAR} images using various image processing techniques. These techniques are used to provide high resolutions in {SAR} images and detect the accuracy of each images.},
	eventtitle = {2020 6th International Conference on Advanced Computing and Communication Systems ({ICACCS})},
	pages = {1097--1100},
	booktitle = {2020 6th International Conference on Advanced Computing and Communication Systems ({ICACCS})},
	publisher = {{IEEE}},
	author = {Ramkumar, G. and Parkavi, P. and Ramya, K. and Priya, M. Swarna},
	date = {2020-03},
	langid = {english},
	file = {PDF:/home/andrianarivovny/snap/zotero-snap/common/Zotero/storage/WHIW624C/Ramkumar et al. - 2020 - A Survey On Sar Images Using Image Processing Techniques.pdf:application/pdf},
}
